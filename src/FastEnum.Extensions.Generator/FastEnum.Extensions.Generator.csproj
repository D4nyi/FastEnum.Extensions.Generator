<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
	  <LangVersion>Latest</LangVersion>

	  <Nullable>enable</Nullable>

	  <EnableNETAnalyzers>True</EnableNETAnalyzers>
	  <AnalysisMode>All</AnalysisMode>
	  <AnalysisLevel>latest-all</AnalysisLevel>
	  <EnforceCodeStyleInBuild>True</EnforceCodeStyleInBuild>
	  <RunAnalyzersDuringBuild>True</RunAnalyzersDuringBuild>

	  <PackageId>$(AssemblyName)</PackageId>
	  <Authors>Dániel Szöllősi</Authors>
	  <RepositoryType>git</RepositoryType>
	  <PackageReadmeFile>README.md</PackageReadmeFile>
	  <PackageTags>Enum, Extensions, Enum-Extensions, Fast, Efficient, Source Generator</PackageTags>
	  <RepositoryUrl>https://github.com/D4nyi/FastEnumToString</RepositoryUrl>
	  <PackageProjectUrl>https://github.com/D4nyi/FastEnumToString</PackageProjectUrl>
	  <Description>Source Generator generating extension methods for enums</Description>
	  <PackageLicenseExpression>MIT</PackageLicenseExpression>

	  <PackageReleaseNotes></PackageReleaseNotes>

	  <DebugType>portable</DebugType>

	  <EnforceExtendedAnalyzerRules>True</EnforceExtendedAnalyzerRules>

	  <PackageVersion>1.0.0</PackageVersion>
	  <Version>1.0.0</Version>
	  <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
	  <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
	  <DevelopmentDependency>true</DevelopmentDependency>
	  <IsPackable>true</IsPackable>
	  <ApplicationIcon>enum.ico</ApplicationIcon>
	  <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
	  <IncludeBuildOutput>false</IncludeBuildOutput>
	  <RunPostBuildEvent>OnBuildSuccess</RunPostBuildEvent>
	  <PackageIcon>enum.png</PackageIcon>
	  <PackageIconUrl>https://github.com/D4nyi/FastEnumToString/blob/master/FastEnumToString/enum.svg</PackageIconUrl>
  </PropertyGroup>

  <ItemGroup>
	  <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4" PrivateAssets="all" />
	  <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.7.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="bin\Debug\netstandard2.0\\FastEnum.Extensions.Generator.dll" />
  </ItemGroup>

	<ItemGroup>
		<None Include="$(OutputPath)\$(AssemblyName).dll">
			<Pack>True</Pack>
			<PackagePath>/analyzers/dotnet/cs</PackagePath>
			<Visible>False</Visible>
		</None>
		<None Include="..\..\README.md" Link="README.md">
		  <PackagePath>\</PackagePath>
		  <Pack>True</Pack>
		</None>

		<None Update="enum.png">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
</Project>
